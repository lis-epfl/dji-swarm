<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Video surface fills the screen -->
    <SurfaceView
        android:id="@+id/surface_video"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <!-- Top overlay: status bar -->
    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:orientation="vertical"
        android:background="#88000000"
        android:padding="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_status"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Initializing..."
                android:textColor="#00ff00"
                android:textSize="14sp"/>

            <TextView
                android:id="@+id/tv_ip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="IP: --"
                android:textColor="#aaaaaa"
                android:textSize="12sp"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tv_vs_state"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="VS: -- | Auth: --"
            android:textColor="#ffcc00"
            android:textSize="12sp"
            android:layout_marginTop="2dp"/>
    </LinearLayout>

    <!-- Right-side telemetry panel -->
    <LinearLayout
        android:id="@+id/telemetry_panel"
        android:layout_width="260dp"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_below="@id/top_bar"
        android:orientation="vertical"
        android:background="#AA000000"
        android:padding="8dp"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DRONE TELEMETRY"
            android:textColor="#00ff00"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tv_telem_gps"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="GPS: --"
            android:textColor="#cccccc"
            android:textSize="11sp"
            android:fontFamily="monospace"/>

        <TextView
            android:id="@+id/tv_telem_attitude"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ATT: --"
            android:textColor="#cccccc"
            android:textSize="11sp"
            android:fontFamily="monospace"/>

        <TextView
            android:id="@+id/tv_telem_gimbal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="GMB: --"
            android:textColor="#cccccc"
            android:textSize="11sp"
            android:fontFamily="monospace"/>

        <TextView
            android:id="@+id/tv_telem_velocity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="VEL: --"
            android:textColor="#cccccc"
            android:textSize="11sp"
            android:fontFamily="monospace"/>
    </LinearLayout>

    <!-- Bottom overlay: commands + controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="vertical"
        android:background="#88000000"
        android:padding="8dp">

        <TextView
            android:id="@+id/tv_telemetry"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No commands"
            android:textColor="#cccccc"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <Button
                android:id="@+id/btn_start_rtsp"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Start RTSP"
                android:textSize="12sp"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btn_enable_vs"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Enable VS"
                android:textSize="12sp"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btn_disable_vs"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Disable VS"
                android:textSize="12sp"/>
        </LinearLayout>
    </LinearLayout>

</RelativeLayout>
